DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/urlshortener
BASE_URL=http://localhost:8000
SHORT_CODE_LENGTH=7
DEFAULT_RATE_LIMIT=60/minute
URL_MAX_AGE_DAYS=1
CORS_ORIGINS=["*"]

# Auth
AUTH_ENABLED=true
API_TOKENS=["dev-token-change-me"]

# JWT (optional if API_TOKENS is set)
JWT_SECRET=change-me-jwt-secret-with-32-plus-characters
JWT_ALGORITHM=HS256
# JWT_AUDIENCE=urlshortener-api

# Advanced route pattern config (usually keep defaults)
AUTH_PROTECTED_ROUTE_PATTERNS=["/api/urls/*"]
AUTH_EXEMPT_ROUTE_PATTERNS=["GET /health","GET /favicon.ico","GET /docs","GET /redoc","GET /openapi.json","GET /{short_code}"]
